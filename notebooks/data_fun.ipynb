    "# 2. Heatmap builder\n",
    "def make_heatmap(rows, image_size=512, target_class=None):\n",
    "    heatmap = np.zeros((image_size, image_size), dtype=np.float32)\n",
    "\n",
    "    for row in rows:\n",
    "        if target_class is not None and row[\"fg_class\"] != target_class:\n",
    "            continue\n",
    "\n",
    "        x, y, w, h = row[\"bbox\"]\n",
    "\n",
    "        x = int(round(x * image_size))\n",
    "        y = int(round(y * image_size))\n",
    "        w = int(round(w * image_size))\n",
    "        h = int(round(h * image_size))\n",
    "\n",
    "        x1 = max(0, x)\n",
    "        y1 = max(0, y)\n",
    "        x2 = min(image_size, x + w)\n",
    "        y2 = min(image_size, y + h)\n",
    "\n",
    "        if x2 > x1 and y2 > y1:\n",
    "            heatmap[y1:y2, x1:x2] += 1\n",
    "\n",
    "    return heatmap\n",
