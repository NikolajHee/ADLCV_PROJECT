    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "import torchvision.transforms as T\n",
    "from PIL import Image\n",
    "\n",
    "transform = T.Compose([\n",
    "    T.Resize(512),\n",
    "    T.CenterCrop(512),\n",
    "    T.ToTensor()\n",
    "])\n",
    "\n",
    "def load_background_image(places_root, bg_path):\n",
    "    img_path = os.path.join(places_root, bg_path)\n",
    "    return transform(Image.open(img_path).convert(\"RGB\"))\n",
    "\n",
    "def normalize_heatmap(heatmap):\n",
    "    if heatmap.max() > 0:\n",
    "        return heatmap / heatmap.max()\n",
    "    return heatmap\n",
    "\n",
    "def show_heatmap_on_image(image_tensor, heatmap, alpha=0.5):\n",
    "    image = image_tensor.permute(1, 2, 0).cpu().numpy()\n",
    "\n",
    "    plt.figure(figsize=(6, 6))\n",
    "    plt.imshow(image)\n",
    "    plt.imshow(heatmap, cmap=\"hot\", alpha=alpha)\n",
    "    plt.colorbar(label=\"Normalized overlap\")\n",
    "    plt.axis(\"off\")\n",
    "    plt.show()"
   ]
  },
